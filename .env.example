# ============================================================
#                    VARIABLES DE ENTORNO
# ============================================================
# Copiar este archivo como .env y completar los valores
# cp .env.example .env
# ============================================================

# --- PostgreSQL Local (Base Maestra) ---
# Credenciales del usuario creado en PostgreSQL
DATABASE_URL=postgresql://dime_user:dime_pass_2026@localhost:5432/dime_maestra

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=supersecretkey_change_in_production
APP_DEBUG=true

# --- Mercado Libre API (OAuth 2.0) ---
ML_CLIENT_ID=your_ml_client_id
ML_CLIENT_SECRET=your_ml_client_secret
ML_REDIRECT_URI=http://localhost:8000/auth/ml/callback
ML_SANDBOX_MODE=true

# --- Metabase Local ---
METABASE_URL=http://localhost:3000
METABASE_USER=admin@dime.local
METABASE_PASSWORD=admin123
