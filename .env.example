# ============================================================
#                    VARIABLES DE ENTORNO
# ============================================================

# --- PostgreSQL Local (Base Maestra) ---
DATABASE_URL=postgresql://db_user:password@localhost:5432/db_name

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=supersecretkey_change_in_production
APP_DEBUG=true

# --- Mercado Libre API (OAuth 2.0) ---
ML_CLIENT_ID=your_ml_client_id
ML_CLIENT_SECRET=your_ml_client_secret
ML_REDIRECT_URI=http://localhost:8000/auth/ml/callback
ML_SANDBOX_MODE=true

# --- Metabase Local ---
METABASE_URL=http://localhost:3000
METABASE_USER=user_email_here
METABASE_PASSWORD=user_password_here