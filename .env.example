# ============================================================
#                    VARIABLES DE ENTORNO
# ============================================================

# --- PostgreSQL (Base Maestra) ---
DB_MAESTRA_HOST=localhost
DB_MAESTRA_PORT=5432
DB_MAESTRA_NAME=dime_maestra
DB_MAESTRA_USER=postgres
DB_MAESTRA_PASSWORD=changeme

# --- PostgreSQL (Cliente por defecto para pruebas) ---
DB_CLIENT_HOST=localhost
DB_CLIENT_PORT=5432
DB_CLIENT_USER=postgres
DB_CLIENT_PASSWORD=changeme

# --- Metabase (usuario de solo lectura) ---
METABASE_DB_USER=metabase_reader
METABASE_DB_PASSWORD=readonly

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=supersecretkey_change_in_production
APP_DEBUG=true

# --- Mercado Libre API (OAuth 2.0) ---
ML_CLIENT_ID=your_ml_client_id
ML_CLIENT_SECRET=your_ml_client_secret
ML_REDIRECT_URI=http://localhost:8000/auth/ml/callback
ML_SANDBOX_MODE=true
